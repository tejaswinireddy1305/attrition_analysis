# ====================================================
# SUPERSTORE SQL ANALYSIS PROJECT QUERIES FOR POWER BI 
# ====================================================



# Total Sales & Total Profit
SELECT 
    ROUND(SUM(sales),2) AS total_sales,
    ROUND(SUM(profit),2) AS total_profit 
FROM superstore;


# Total Orders
SELECT 
    COUNT(DISTINCT orderid) AS total_orders 
FROM superstore;


# Average Order Value (AOV)
SELECT 
    ROUND(SUM(quantityorderednew * unitprice) / COUNT(DISTINCT orderid), 2) AS avg_order_value
FROM superstore;


# Profit Margin (%)
SELECT 
    ROUND(SUM(profit) / SUM(sales) * 100, 2) AS profit_margin
FROM superstore;


# Monthly Sales Trend
SELECT 
    MONTH(orderdate) AS month,
    ROUND(SUM(sales),2) AS monthly_sales
FROM superstore
GROUP BY MONTH(orderdate)
ORDER BY month;


# Regional Sales & Profit Performance
SELECT 
    region,
    ROUND(SUM(sales),2) AS total_sales,
    ROUND(SUM(profit),2) AS total_profit 
FROM superstore 
GROUP BY region 
ORDER BY total_sales DESC;


# Sales by Customer Segment
SELECT 
    customersegment,
    ROUND(SUM(sales),2) AS total_sales
FROM superstore
GROUP BY customersegment;


# City-wise Sales Distribution
SELECT 
    city,
    SUM(sales) AS total_sales 
FROM superstore 
GROUP BY city;


# Sales & Profit by Product Category
SELECT 
    ProductCategory,
    ROUND(SUM(sales),2) AS total_sales,
    ROUND(SUM(profit),2) AS total_profit
FROM superstore
GROUP BY ProductCategory;


# Profit by Product Sub-Category
SELECT 
    productsubcategory,
    ROUND(SUM(profit),2) AS total_profit
FROM superstore
GROUP BY productsubcategory;


# Sales vs Profit (Scatter Plot Data)
SELECT 
    orderid,
    sales,
    profit,
    quantityorderednew
FROM superstore;


# Discount Impact on Profitability
SELECT 
    CASE 
        WHEN discount = 0 THEN 'No Discount'
        WHEN discount BETWEEN 0.01 AND 0.20 THEN 'Low Discount'
        WHEN discount BETWEEN 0.21 AND 0.50 THEN 'Medium Discount'
        ELSE 'High Discount'
    END AS discount_range,
    ROUND(SUM(profit),2) AS total_profit
FROM superstore
GROUP BY discount_range;


# Loss-Making Orders
SELECT 
    orderid,
    sales,
    profit
FROM superstore
WHERE profit < 0


# Top 10 Customers by Sales
SELECT 
    customername,
    ROUND(SUM(sales),2) AS total_sales 
FROM superstore 
GROUP BY customername 
ORDER BY total_sales DESC 
LIMIT 10;


# Repeat Customers Analysis
SELECT 
    customername,
    COUNT(DISTINCT orderid) AS total_orders,
    ROUND(SUM(sales),2) AS total_sales
FROM superstore
GROUP BY customername
HAVING total_orders > 1;


# Customer Segment Performance
SELECT 
    customersegment,
    ROUND(SUM(sales),2) AS total_sales,
    ROUND(SUM(profit),2) AS total_profit
FROM superstore
GROUP BY customersegment;


# Product Performance Analysis
SELECT 
    ProductName,
    SUM(sales) AS total_sales,
    SUM(profit) AS total_profit 
FROM superstore 
GROUP BY ProductName 
ORDER BY total_sales DESC;


# Top 5 Most Profitable Sub-Categories
SELECT 
    productsubcategory,
    ROUND(SUM(profit),2) AS total_profit
FROM superstore
GROUP BY productsubcategory
ORDER BY total_profit DESC
LIMIT 5;



# Year-wise Sales & Profit Growth
SELECT 
    YEAR(orderdate) AS year,
    ROUND(SUM(sales),2) AS total_sales,
    ROUND(SUM(profit),2) AS total_profit
FROM superstore
GROUP BY YEAR(orderdate)
ORDER BY year;


# Shipping Mode Performance Analysis
SELECT 
    ShipMode,
    ROUND(AVG(DATEDIFF(shipdate, orderdate)), 2) AS avg_delivery_days,
    ROUND(SUM(ShippingCost), 2) AS total_shipping_cost
FROM superstore
GROUP BY ShipMode;


# Delivery Delay Impact on Profit
SELECT 
    DATEDIFF(shipdate, orderdate) AS delivery_days,
    ROUND(AVG(profit),2) AS avg_profit
FROM superstore
GROUP BY delivery_days;


# Top Cities by Profit
SELECT 
    city,
    ROUND(SUM(profit),2) AS total_profit
FROM superstore
GROUP BY city
ORDER BY total_profit DESC;


# Customer Lifetime Value (CLV)
SELECT 
    customername,
    ROUND(SUM(sales),2) AS lifetime_sales,
    ROUND(SUM(profit),2) AS lifetime_profit
FROM superstore
GROUP BY customername;


# Running Total Sales (Cumulative Growth)
SELECT 
    orderdate,
    ROUND(SUM(sales),2) AS daily_sales,
    ROUND(SUM(SUM(sales)) OVER (ORDER BY orderdate),2) AS running_total_sales
FROM superstore
GROUP BY orderdate;


# Seasonal Sales Analysis
SELECT 
    CASE 
        WHEN MONTH(OrderDate) IN (12, 1, 2) THEN 'Winter'
        WHEN MONTH(OrderDate) IN (3, 4, 5) THEN 'Spring'
        WHEN MONTH(OrderDate) IN (6, 7, 8) THEN 'Summer'
        ELSE 'Fall'
    END AS season,
    SUM(Sales) AS total_sales
FROM superstore
GROUP BY season;
